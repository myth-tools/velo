{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Velo",
  "version": "0.1.0",
  "identifier": "dev.velo",
  "build": {
    "beforeDevCommand": "cd ../ui && pnpm dev",
    "beforeBuildCommand": "cd ../ui && pnpm build",
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Velo",
        "width": 720,
        "height": 72,
        "minWidth": 140,
        "minHeight": 140,
        "maxWidth": 1440,
        "maxHeight": 900,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": false,
        "center": true,
        "skipTaskbar": false,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
